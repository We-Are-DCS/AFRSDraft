# ── Microsoft Entra (Azure AD) SSO — DCS ─────────────────────────────────────
# Create an App Registration in the Entra admin center (SPA platform),
# then copy these values here and into your Vercel project's Environment
# Variables (Production + Preview).
#
# Application (client) ID of the App Registration
VITE_ENTRA_CLIENT_ID=
# DCS directory (tenant) ID — single-tenant authority
VITE_ENTRA_TENANT_ID=
# Optional: override the redirect URI. Defaults to the current site origin
# (http://localhost:5174 in dev, https://afrs-emulator.vercel.app in prod).
# VITE_ENTRA_REDIRECT_URI=

# ── Audit trail (optional) ───────────────────────────────────────────────────
# Auth events are always stored in the browser's localStorage. If this is set,
# each event is also POSTed (fire-and-forget JSON) to this endpoint, so the
# trail can be centralised once a backend exists.
# VITE_AUDIT_ENDPOINT=https://your-audit-api.example.com/events
